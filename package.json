{
  "name": "promptly-ai",
  "version": "1.2.1",
  "description": "AI Prompt Management Tool",
  "main": "dist-electron/main/index.js",
  "author": "codename19",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build && electron-builder",
    "preview": "vite preview",
    "electron:dev": "vite",
    "electron:build": "vite build && electron-builder",
    "release": "electron-builder --publish always"
  },
  "dependencies": {
    "@vueuse/core": "^10.9.0",
    "electron-updater": "^6.8.3",
    "marked": "^17.0.5",
    "nodemailer": "^8.0.3",
    "pinia": "^2.1.7",
    "sql.js": "^1.10.2",
    "vue": "^3.4.21",
    "vue-i18n": "^11.3.0",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@types/nodemailer": "^7.0.11",
    "@vitejs/plugin-vue": "^5.0.4",
    "autoprefixer": "^10.4.18",
    "dotenv": "^17.3.1",
    "electron": "^29.1.4",
    "electron-builder": "^24.13.3",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.4.2",
    "vite": "^5.2.0",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vue-tsc": "^2.0.6"
  },
  "build": {
    "appId": "com.promptly.ai",
    "productName": "Promptly AI",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "sql-wasm.wasm"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Promptly AI",
      "deleteAppDataOnUninstall": true,
      "perMachine": false
    },
    "publish": {
      "provider": "github",
      "owner": "OYYH-Apple",
      "repo": "Promptly-AI"
    }
  }
}
